# ============================================================
#  PolyLance Frontend — Environment Variables
#  Copy this file to .env and fill in your values.
#  All VITE_ variables are exposed to the browser bundle.
#  Never put private keys or secrets in VITE_ variables.
# ============================================================

# ── Network ───────────────────────────────────────────────
# Polygon Amoy testnet chain ID
VITE_CHAIN_ID=80002
# RPC URL used by the frontend (can be public or your own key)
VITE_RPC_URL=https://rpc-amoy.polygon.technology/

# ── Contract Addresses ────────────────────────────────────
VITE_ESCROW_ADDRESS=0x25F6C8ed995C811E6c0ADb1D66A60830E8115e9A
VITE_REPUTATION_ADDRESS=0x89791A9A3210667c828492DB98DCa3e2076cc373
VITE_POLY_TOKEN_ADDRESS=0xd3b893cd083f07Fe371c1a87393576e7B01C52C6
VITE_SBT_ADDRESS=0xb4e9A5BC64DC07f890367F72941403EEd7faDCbB
VITE_GOVERNANCE_ADDRESS=0x4653251486a57f90Ee89F9f34E098b9218659b83
VITE_FORWARDER_ADDRESS=0x0000000000000000000000000000000000000000

# ── The Graph ─────────────────────────────────────────────
# The Graph hosted service or decentralized network endpoint
VITE_GRAPH_URL=https://api.studio.thegraph.com/query/your_subgraph_id/polylance/v0.0.1

# ── Biconomy ──────────────────────────────────────────────
# Biconomy Paymaster API key (used in frontend SDK)
VITE_BICONOMY_PAYMASTER_API_KEY=your_biconomy_paymaster_key
# Biconomy Bundler URL for UserOperation submission
VITE_BICONOMY_BUNDLER_URL=https://bundler.biconomy.io/api/v2/80002/your_key

# ── XMTP ──────────────────────────────────────────────────
# XMTP network environment: 'dev' | 'production'
VITE_XMTP_ENV=dev

# ── IPFS / Storage ────────────────────────────────────────
# Fleek / NFT.Storage API key for IPFS uploads
VITE_IPFS_GATEWAY=https://cloudflare-ipfs.com/ipfs/
VITE_FLEEK_API_KEY=your_fleek_api_key

# ── Feature Flags ─────────────────────────────────────────
# Set to true to enable experimental RWA invoice module in UI
VITE_ENABLE_RWA=false
# Set to true to show Solana cross-chain features
VITE_ENABLE_CROSS_CHAIN=false
