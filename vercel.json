{
  "version": 2,
  "installCommand": "npm install --prefix frontend",
  "buildCommand": "npx cross-env NODE_OPTIONS=--max-old-space-size=4096 npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
