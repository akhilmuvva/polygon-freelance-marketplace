{
    "$schema": "./v-schema.json",
    "name": "polylance-root",
    "version": "1.0.0",
    "author": "Akhil Muvva",
    "contributors": [
        "Jhansi Kupireddy"
    ],
    "private": true,
    "scripts": {
        "install:all": "npm install --prefix backend --legacy-peer-deps && cd frontend && yarn install --ignore-engines && cd ..",
        "build": "npm run build --prefix frontend",
        "build:frontend": "npm run build --prefix frontend",
        "build:contracts": "npm run compile --prefix contracts",
        "start:backend": "npm start --prefix backend",
        "start:frontend": "npm run dev --prefix frontend",
        "lint:all": "npm run lint --prefix backend && npm run lint --prefix frontend"
    },
    "engines": {
        "node": ">=20.19.0"
    }
}